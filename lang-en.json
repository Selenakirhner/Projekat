    "vakcinacijeStranica": {
        "glavniNaslov": "Why is vaccination important?",
        "glavniOpis": "Regular vaccination is the best way to protect your pet from infectious and deadly diseases. Our veterinary team uses the highest quality vaccines and follows all protocols.",
        "naslovPsi": "Vaccinations for dogs:",
        "listaPsi": {
            "stavka1": "<strong>Core vaccine (DHPPi):</strong> Protects against distemper, hepatitis, parvovirus and parainfluenza",
            "stavka2": "<strong>Rabies:</strong> Mandatory vaccine by law",
            "stavka3": "<strong>Bordetella:</strong> Protection against upper respiratory infections",
            "stavka4": "<strong>Lyme disease:</strong> Recommended for dogs that spend time outdoors"
        },
        "naslovMacke": "Vaccinations for cats:",
        "listaMacke": {
            "stavka1": "<strong>Core vaccine (FVRCP):</strong> Protects against panleukopenia, calicivirus and rhinotracheitis",
            "stavka2": "<strong>Rabies:</strong> Mandatory vaccine",
            "stavka3": "<strong>FeLV:</strong> Vaccine against leukemia"
        },
        "kadaNaslov": "When to vaccinate?",
        "tabela": {
            "zaglavlje1": "Age",
            "zaglavlje2": "Recommended vaccination",
            "red1": {
                "kolona1": "6-8 weeks",
                "kolona2": "First vaccination"
            },
            "red2": {
                "kolona1": "12 weeks",
                "kolona2": "Second vaccination + rabies"
            },
            "red3": {
                "kolona1": "16 weeks",
                "kolona2": "Third vaccination (if needed)"
            },
            "red4": {
                "kolona1": "Yearly",
                "kolona2": "Revaccination"
            }
        },
        "cenaKartica": {
            "naslov": "Vaccination price",
            "stavka1": "Core vaccine (dogs)",
            "stavka2": "Core vaccine (cats)",
            "stavka3": "Rabies vaccine",
            "ukupno": "Package (all vaccines)"
        },
        "kontaktBocno": {
            "naslov": "Schedule an appointment",
            "radnoVreme": "Mon-Fri: 10am-6pm",
            "dugme": "Schedule now"
        },
        "napomena": {
