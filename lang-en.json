    "mikrocipStranica": {
        "naslov": "Microchipping dogs and cats",
        "opis": "A microchip is a permanent identification for your pet. Mandatory by law for all dogs, and recommended for cats.",
        "staJeNaslov": "What is a microchip?",
        "staJeTekst": "A microchip is an electronic identifier the size of a grain of rice that is injected under the skin. It contains a unique number that is entered into the central registry.",
        "postupakNaslov": "Microchipping procedure:",
        "koraci": {
            "korak1": "<strong>Examination:</strong> Short clinical examination",
            "korak2": "<strong>Injection:</strong> Quick and painless, like a vaccination",
            "korak3": "<strong>Scanning:</strong> Checking if the chip is readable",
            "korak4": "<strong>Registry entry:</strong> Entering data into the central database",
            "korak5": "<strong>You receive a passport:</strong> With all chip information"
        },
        "cene": {
            "naslov": "Prices",
            "stavka1": "Microchip + registration",
            "stavka2": "Dog (with valid passport)",
            "stavka3": "Cats"
        }
    },
    "preglediStranica": {
        "naslov": "Health Checkups",
        "opis": "Regular checkups are key to a long and healthy life for your pet.",
        "ukljucujeNaslov": "What does the checkup include?",
        "ukljucujeLista": {
            "stavka1": "<strong>Clinical examination:</strong> Temperature, pulse, breathing",
            "stavka2": "<strong>Ear and eye examination:</strong> Infections, foreign objects",
            "stavka3": "<strong>Dental examination:</strong> Tartar, gum inflammation",
            "stavka4": "<strong>Skin and coat examination:</strong> Parasites, allergies",
            "stavka5": "<strong>Heart and lung examination:</strong> With stethoscope",
            "stavka6": "<strong>Abdominal palpation:</strong> Organs, painful spots"
        },
        "dodatniNaslov": "Additional examinations:",
        "dodatniLista": {
            "stavka1": "Ultrasound - 2,500 RSD",
            "stavka2": "X-ray - 3,000 RSD",
            "stavka3": "Blood count - 1,800 RSD",
            "stavka4": "Biochemistry - 2,200 RSD"
        },
        "cenaKartica": {
            "naslov": "Examination price",
            "stavka1": "Clinical examination"
        }
    },
    "sterilizacijaStranica": {
        "naslov": "Sterilization and Castration",
        "opis": "Sterilization is a responsible act of every owner. It helps control the population, reduces the risk of certain diseases, and extends the pet's lifespan.",
        "prednostiNaslov": "Benefits of sterilization:",
        "prednostiLista": {
            "stavka1": "<strong>Reduces the risk of mammary tumors</strong> (especially if done before the first heat)",
            "stavka2": "<strong>Eliminates the risk of pyometra</strong> - uterine infection",
            "stavka3": "<strong>Reduces aggression</strong> and the urge to roam",
            "stavka4": "<strong>No unwanted puppies</strong> - responsible ownership",
            "stavka5": "<strong>Extends lifespan</strong> by an average of 1-3 years"
        },
        "kadaNaslov": "When to sterilize?",
        "kadaTekst": "Recommended between 6 and 12 months of age, depending on the breed and size of the dog. For smaller breeds it can be done earlier, for larger ones later.",
        "cene": {
            "naslov": "Sterilization prices",
            "stavka1": "Male - dog (up to 15kg)",
            "stavka2": "Male - dog (15-30kg)",
            "stavka3": "Male - dog (over 30kg)",
            "stavka4": "Female - dog (up to 15kg)",
            "stavka5": "Female - dog (15-30kg)",
            "stavka6": "Female - dog (over 30kg)",
            "stavka7": "Cats (male/female)"
        }
    },
